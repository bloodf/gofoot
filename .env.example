# Database
# Local dev (default): SQLite file via @libsql/client — NO Turso account needed
TURSO_DATABASE_URL=file:./.data/gofoot.db
TURSO_AUTH_TOKEN=
# Production only (remote Turso):
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=...

# HMAC secret for session tokens + audit chain (min 32 random bytes)
SESSION_HMAC_SECRET=dev-only-change-me-to-32bytes-min!!

# Live football data (teams + players) — NOT local JSON at runtime
# TheSportsDB free key "3" works without signup. Premium key raises limits.
THESPORTSDB_API_KEY=3
# Optional: football-data.org free token for Brasileirão BSA
# FOOTBALL_DATA_API_TOKEN=
